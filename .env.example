# ── Chain RPCs ─────────────────────────────────────────────────────────
UNICHAIN_SEPOLIA_RPC=https://sepolia.unichain.org
UNICHAIN_MAINNET_RPC=https://mainnet.unichain.org
ETHEREUM_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ── Uniswap v4 Deployed Addresses (Unichain Sepolia) ──────────────────
# Official PoolManager on Unichain Sepolia (do not change)
POOL_MANAGER_ADDRESS=0x00B036B58a818B1BC34d502D3fE730Db729e62AC
POSITION_MANAGER_ADDRESS=0xf969Aee60879C54bAAed9F3eD26147Db216Fd664

# ── HookMind Deployed Addresses (set after `forge script Deploy`) ──────
HOOK_MIND_CORE_ADDRESS=0x...
AGENT_REGISTRY_ADDRESS=0x...
YIELD_VAULT_ADDRESS=0x...
IL_INSURANCE_ADDRESS=0x...

# ── Pool Token Addresses (used by poolReader to build the PoolKey) ─────
# Must match the currencies passed to PoolManager.initialize()
POOL_CURRENCY0=0x...
POOL_CURRENCY1=0x...

# ── Target Pool ────────────────────────────────────────────────────────
# bytes32 PoolId returned by key.toId() after pool initialization
TARGET_POOL_ID=0x...

# ── Circle / USDC ─────────────────────────────────────────────────────
USDC_UNICHAIN=0x078D782b760474a361dDA30f7B6B4AD1bf9b58b7
CCTP_TOKEN_MESSENGER=0x...

# ── Deployer ──────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x...
# The EOA that will be registered as the agent in AgentRegistry
AGENT_EOA_ADDRESS=0x...

# ── Agent Engine ──────────────────────────────────────────────────────
# Private key the agent daemon uses to sign hook signals (ECDSA)
AGENT_PRIVATE_KEY=0x...
AGENT_UPDATE_INTERVAL_MS=12000

# ── LLM Providers ────────────────────────────────────────────────────
# Set ACTIVE_LLM_PROVIDER to one of: anthropic | openai | gemini | grok | ollama | mock
# Use "mock" only for local testing — it returns a hardcoded fee and never calls an LLM.
ACTIVE_LLM_PROVIDER=anthropic
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
GROK_API_KEY=xai-...

# ── IPFS / Pinata ────────────────────────────────────────────────────
PINATA_JWT=eyJ...
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Agent API Server ─────────────────────────────────────────────────
PORT=4000
# REQUIRED: JWT secret for institutional API auth. Must be set — no default.
API_JWT_SECRET=your-strong-random-secret-here

# ── Frontend (Next.js NEXT_PUBLIC_ vars) ─────────────────────────────
NEXT_PUBLIC_POOL_MANAGER=0x00B036B58a818B1BC34d502D3fE730Db729e62AC
# Must match HOOK_MIND_CORE_ADDRESS above
NEXT_PUBLIC_HOOK_ADDRESS=0x...
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_SUBGRAPH_URL=https://api.thegraph.com/subgraphs/name/hookmind
NEXT_PUBLIC_WALLETCONNECT_ID=your-walletconnect-project-id

# ── DB / Backend ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://...

# ── EigenLayer AVS (optional) ─────────────────────────────────────────
AVS_OPERATOR_ADDRESS=0x...
AVS_REGISTRY_COORDINATOR=0x...
